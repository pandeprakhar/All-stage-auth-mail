
#############################################
# Application Configuration
#############################################

# Application Name
APP_NAME="Allstag Backend"

# Environment (development / production)
APP_ENV=development

# Enable or Disable Debug Mode
APP_DEBUG=true

# Base URL of the Backend
APP_URL=http://localhost/backend/public


#############################################
# Database Configuration
#############################################

# Database Host
DB_HOST=127.0.0.1

# Database Port
DB_PORT=3306

# Database Name
DB_DATABASE=allstag

# Database Username
DB_USERNAME=allstag

# Database Password
DB_PASSWORD=Admin@123


#############################################
# JWT Authentication
#############################################

# Secret Key used to sign JWT Tokens
# Change this to a long random string before deploying to production
JWT_SECRET=ChangeThisLaterToRandomString


#############################################
# Timezone
#############################################

# Server Timezone
TIMEZONE=Asia/Kolkata


#############################################
# Mail Configuration (SMTP)
#############################################

# SMTP Server
MAIL_HOST=smtp.gmail.com

# SMTP Port
MAIL_PORT=587

# Gmail Username
MAIL_USERNAME=pande.prakhar007@gmail.com

# Gmail App Password
MAIL_PASSWORD=khpgbxyevshmzyai

# Sender Email
MAIL_FROM=pande.prakhar007@gmail.com

# Sender Name
MAIL_FROM_NAME=AllStage